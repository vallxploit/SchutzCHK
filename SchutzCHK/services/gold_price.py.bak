import json
import time
import os
import requests
from datetime import datetime

CACHE_FILE = "cache/gold_price.json"
CACHE_TTL = 43200  # 12 jam

# API gratis pake goldapi.io (daftar dapet key)
GOLD_API_KEY = ""  # KOSONGI DULU, nanti isi kalo punya
GOLD_API_URL = "https://www.goldapi.io/api/XAU/IDR"

HEADERS = {
    "x-access-token": GOLD_API_KEY,
    "Content-Type": "application/json"
}


def _load_cache():
    if not os.path.exists(CACHE_FILE):
        return None
    
    with open(CACHE_FILE, "r") as f:
        data = json.load(f)
    
    if time.time() - data["last_update"] > CACHE_TTL:
        return None
    
    return data


def _save_cache(price_usd: float, price_idr: float):
    os.makedirs("cache", exist_ok=True)
    
    data = {
        "price_usd": price_usd,
        "price_idr": price_idr,
        "last_update": int(time.time()),
        "last_update_str": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    }
    
    with open(CACHE_FILE, "w") as f:
        json.dump(data, f, indent=2)
    
    return data


def _fetch_from_api():
    """Ambil harga emas dari API"""
    try:
        if not GOLD_API_KEY:
            raise Exception("API key not set")
        
        response = requests.get(GOLD_API_URL, headers=HEADERS, timeout=10)
        
        if response.status_code != 200:
            raise Exception(f"API error: {response.status_code}")
        
        data = response.json()
        
        # Harga per gram dalam IDR
        price_gram_idr = data.get("price_gram_24k", 0)
        price_gram_usd = data.get("price_gram_24k", 0) / data.get("currency_rate", 15500)
        
        if price_gram_idr == 0:
            raise Exception("Invalid price from API")
        
        return price_gram_usd, price_gram_idr
        
    except Exception as e:
        print(f"⚠️ Gold API error: {e}, using fallback price")
        # FALLBACK HARGA REALISTIS (per 13 Juni 2026)
        # Harga emas ~1,300,000 IDR/gram
        return 85.0, 1300000  # 85 USD/gram, 1.3jt IDR/gram


def get_gold_price():
    """Ambil harga emas (dengan cache 12 jam)"""
    cache = _load_cache()
    
    if cache:
        return cache["price_usd"], cache["price_idr"]
    
    price_usd, price_idr = _fetch_from_api()
    _save_cache(price_usd, price_idr)
    
    return price_usd, price_idr


def get_rsm_rate():
    """
    1 RSM = harga emas per gram / 100
    Biar gak milyaran
    """
    _, gold_idr = get_gold_price()
    rsm_rate = round(gold_idr / 100, 2)  # Dibagi 100, bukan 10
    return rsm_rate
