client = create_client_sync(url=DB_URL, auth_token=DB_TOKEN)


def get_history(telegram_id: int, limit: int = 20):
    result = client.execute(
        """
        SELECT *
        FROM ledger
        WHERE user_id = ?
        ORDER BY timestamp DESC
        LIMIT ?
        """,
        [telegram_id, limit]
    )

    return [
        {
            "type": row[1],
            "amount": row[2],
            "before": row[3],
            "after": row[4],
            "desc": row[5],
            "time": row[6]
        }
        for row in result.rows
    ]